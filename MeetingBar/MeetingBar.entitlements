<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- Sandbox OFF for personal/dev use: simpler to run locally without
	     signing gymnastics. If you ever ship to the App Store, flip this
	     to true and add com.apple.security.personal-information.calendars. -->
	<key>com.apple.security.app-sandbox</key>
	<false/>
</dict>
</plist>
